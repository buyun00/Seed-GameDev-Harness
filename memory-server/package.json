{
  "name": "memory-server",
  "version": "0.1.0",
  "description": "Seed Memory Editor - Knowledge Layer Management with Web UI",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts -- daemon --project-path .",
    "build": "npm run build:client && npm run build:worker",
    "build:client": "vite build",
    "build:worker": "esbuild server/index.ts --bundle --platform=node --target=node18 --outfile=dist/worker.cjs --format=cjs --external:@anthropic-ai/claude-agent-sdk",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/worker.cjs daemon --project-path .",
    "typecheck": "vue-tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "worker:start": "node dist/worker.cjs start",
    "worker:stop": "node dist/worker.cjs stop",
    "worker:status": "node dist/worker.cjs status",
    "worker:restart": "node dist/worker.cjs restart"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^4.0.0",
    "diff": "^7.0.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.6.0",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@kousum/semi-ui-vue": "^2.78.0",
    "@types/diff": "^6.0.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vueuse/core": "^12.0.0",
    "axios": "^1.7.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.24.0",
    "pinia": "^2.2.0",
    "sass": "^1.80.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vditor": "^3.10.0",
    "vite": "^6.0.0",
    "@vitejs/plugin-vue-jsx": "^4.1.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "vue-tsc": "^2.1.0"
  }
}
